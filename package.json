{
  "name": "scoutflow-hq",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check backend/server.js && node --check backend/routes/api.js && node --check backend/services/platformService.js && node --check frontend/app.js",
    "export:seed": "node backend/scripts/exportSeedSql.js",
    "db:check": "node backend/scripts/checkPostgres.js",
    "db:init": "node backend/scripts/initPostgres.js",
    "db:reset": "node backend/scripts/resetPostgres.js",
    "smoke:health": "curl -fsS http://127.0.0.1:4173/api/health"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
